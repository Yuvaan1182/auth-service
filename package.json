{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "",
  "imports": {
    "#config/*": "./src/config/*",
    "#routes/*": "./src/routes/*",
    "#utils/*": "./src/utils/*",
    "#middlewares/*": "./src/middlewares/*",
    "#prisma/*": "./src/generated/prisma/*",
    "#controllers/*": "./src/controllers/*",
    "#constants/*": "./src/constants/*",
    "#types/*": "./src/types/*",
    "#repo/*": "./src/repositories/*",
    "#queue/*": "./src/queue/*",
    "#worker/*": "./src/worker/*",
    "#redis/*": "./src/services/redis/*",
    "#schema/*": "./src/schema/*",
    "#services/*": "./src/services/*",
    "#interface/*": "./src/interface/*",
    "#db/*": "./src/db/*",
    "#factory/*": "./src/factory/*",
    "#container/*": "./src/container/*"
  },
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --inspect src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/worker/email.worker.ts",
    "worker:dev": "tsx watch --inspect=9230 src/worker/email.worker.ts",
    "enqueue:test": "tsx src/scripts/push_test_email.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest --config ./src/test/config/vitest.config.ts",
    "test:run": "vitest --config ./src/test/config/vitest.config.ts run",
    "test:watch": "vitest --watch --config ./src/test/config/vitest.config.ts --reporter=verbose",
    "test:coverage": "vitest --config ./src/test/config/vitest.config.ts run --coverage --reporter=verbose --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.5.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.4",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
